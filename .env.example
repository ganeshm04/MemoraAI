# MemoraAI - Environment Configuration

# ===================
# Supabase Database
# ===================
# Get these from your Supabase project dashboard
# Dashboard: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/database

DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Google Gemini API key(s). For fallback/rotation, provide a comma-separated list (e.g. key1,key2,key3)
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here
DEBUG=true
LOG_LEVEL=info

# ===================
# Backend (backend/.env)
# ===================
NODE_ENV=development
PORT=3000
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT=120000
CORS_ORIGINS=http://localhost:3001

# ===================
# Frontend (frontend/.env)
# ===================
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1