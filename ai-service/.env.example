# MemoraAI AI Service

# Environment Variables
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/memora

# Application
APP_NAME=MemoraAI
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Retrieval Settings
CHUNK_SIZE=700
CHUNK_OVERLAP=100
TOP_K_RETRIEVAL=10
TOP_K_RERANKED=5

# RRF
RRF_K=60

# BM25
BM25_K1=1.5
BM25_B=0.75

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json